PAD_data <- PAD_data %>%
mutate(
category = factor(category, levels = c("animal", "tree", "object")),
session  = factor(session),
numerosity = factor(numerosity)
)
# --- Fit additive model (NO interaction) ---
fit_M0 <- lmer(
Error ~ category + session + numerosity +
(1 | participant_number) + (1 | item_id),
data = PAD_data
)
# --- Fit model interaztion ---
fit_M1 <- lmer(
Error ~ category * session + numerosity +
(1 | participant_number) + (1 | item_id),
data = PAD_data
)
#| label: tbl-Mcomp
#| tbl-cap: "Model comparison using BIC, AICc, and model weights"
#| tbl-cap-location: bottom
#| results: asis
model_set <- list(
additive    = fit_M0,
interaction = fit_M1
)
aic_weights <- model.sel(model_set)
BIC <- BIC(fit_M0, fit_M1)
BICs <- BIC$BIC
AICs <- aic_weights$AICc
weight <- aic_weights$weight
model_table <- data.frame(
Model  = c("Additive", "Interaction"),
BIC    = BICs,
AICc   = AICs,
Weight = weight
) %>%
mutate(
BIC    = round(BIC, 2),
AICc   = round(AICc, 2),
Weight = round(Weight, 3)
)
kable(
model_table,
align = "lccc"
)
#| label: fig-additive
#| fig-cap: "Model based Error prediction for the Additive model (marginal over numerosity)."
#| fig-width: 8
# ============================================================
# Aggregated over numerosity (estimated marginal means)
# (Grid over category x session, but model is additive → parallel patterns)
# ============================================================
emm_agg <- emmeans(fit_M0, ~ category * session)
emm_agg_df <- as.data.frame(emm_agg)
p_agg <- ggplot(emm_agg_df,
aes(x = session, y = emmean, color = category, group = category)) +
geom_hline(yintercept = 0, linetype = "dashed", color = "grey50") +
geom_line(linewidth = 1.2) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = asymp.LCL, ymax = asymp.UCL), width = 0.12) +
theme_bw(base_size = 18) +
theme(
text = element_text(size = 15),
legend.title = element_text(size = 15),
legend.text = element_text(size = 15)
) +
scale_color_manual(
values = c("animal"= '#E69F00',"object"= '#56B4E9',"tree"= '#009E73'),
) +
labs(
x = "Session",
y = "Error",
color = "Category"
)
p_agg
