category = factor(category,
levels = c("animal", "tree", "object")),
session = factor(session)
) %>%
group_by(session, category) %>%
summarise(
mean_error = mean(Error, na.rm = TRUE),
se = sd(Error, na.rm = TRUE) / sqrt(n()),
