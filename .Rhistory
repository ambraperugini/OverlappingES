if (esegui) {
library( effectsize )
fit_cohen <- lm( Cohens_d ~ n*mu*sigma*alpha, data = ALL )
etasq_cohen <- eta_squared( fit_cohen, partial = FALSE )
ETA2 <- etasq_cohen[,c("Parameter","Eta2")]
colnames(ETA2)[2] <- "cohen"
library( betareg )
fit_eta <- betareg( eta1 ~ n*mu*sigma*alpha, data = ALL )
fit_eta_null <- betareg( eta1 ~ 1, data = ALL )
ETA2$eta <- beta_deviance_diff( fit_eta, fit_eta_null )$Proportion_Deviance_Explained
fit_cles <- betareg( Cles ~ n*mu*sigma*alpha, data = ALL )
fit_cles_null <- betareg( Cles ~ 1, data = ALL )
ETA2$cles <- beta_deviance_diff( fit_cles, fit_cles_null )$Proportion_Deviance_Explained
fit_OV <- betareg( OV ~ n*mu*sigma*alpha, data = ALL )
fit_OV_null <- betareg( OV ~ 1, data = ALL )
ETA2$ov <- beta_deviance_diff( fit_OV, fit_OV_null )$Proportion_Deviance_Explained
save( ETA2, file = paste0(datadir,"R02_etasquared.rda"))
} else {
load( paste0(datadir,"R02_etasquared.rda") )
}
kable( ETA2, digits = 2 )
